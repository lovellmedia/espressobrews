---
const navLinks = [
  { href: '/coffee-brewing/', label: 'Overview' },
  { href: '/coffee-brewing/history/', label: 'History' },
  { href: '/coffee-brewing/technical-deep-dive/', label: 'Technical' },
  { href: '/coffee-brewing/ontology/', label: 'Ontology' },
  { href: '/coffee-brewing/trends/', label: 'Trends' },
  { href: '/coffee-brewing/tools/', label: 'Tools' },
  { href: '/coffee-brewing/challenges/', label: 'Challenges' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="/" class="flex items-center gap-2 text-primary">
          <span class="material-symbols-outlined text-3xl">coffee</span>
          <h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold tracking-tight">Espresso Brews</h2>
        </a>
        <nav class="hidden md:flex items-center gap-6">
          {navLinks.slice(0, 4).map(link => (
            <a href={link.href} class="text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors">{link.label}</a>
          ))}
        </nav>
      </div>
      <div class="flex items-center gap-4">
        <a href="/coffee-brewing/" class="bg-primary hover:bg-primary/90 text-white px-5 py-2 rounded text-sm font-bold transition-all">
          Explore Guides
        </a>
      </div>
    </div>
  </div>
</header>
