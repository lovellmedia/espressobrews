---
export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navItems = [
  { href: '/coffee-brewing/', label: 'Overview', key: 'index' },
  { href: '/coffee-brewing/history/', label: 'History & Evolution', key: 'history' },
  { href: '/coffee-brewing/technical-deep-dive/', label: 'Technical Deep-Dive', key: 'technical' },
  { href: '/coffee-brewing/ontology/', label: 'Ontology', key: 'ontology' },
  { href: '/coffee-brewing/trends/', label: 'Trends', key: 'trends' },
  { href: '/coffee-brewing/tools/', label: 'Tools', key: 'tools' },
  { href: '/coffee-brewing/challenges/', label: 'Challenges', key: 'challenges' },
];
---

<nav class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 mb-6">
  <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-4">Coffee Brewing</h3>
  <ul class="space-y-2">
    {navItems.map(item => (
      <li>
        <a 
          href={item.href} 
          class={`block px-3 py-2 rounded text-sm transition-colors ${
            currentPage === item.key 
              ? 'bg-primary text-white' 
              : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700'
          }`}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
