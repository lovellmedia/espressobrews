---
const footerLinks = {
  research: [
    { href: '/coffee-brewing/', label: 'Overview' },
    { href: '/coffee-brewing/history/', label: 'History' },
    { href: '/coffee-brewing/technical-deep-dive/', label: 'Technical' },
    { href: '/coffee-brewing/tools/', label: 'Tools' },
  ],
  company: [
    { href: '/coffee-brewing/ontology/', label: 'Ontology' },
    { href: '/coffee-brewing/trends/', label: 'Trends' },
    { href: '/coffee-brewing/challenges/', label: 'Challenges' },
  ],
  social: [
    { href: '#', label: 'LinkedIn' },
    { href: '#', label: 'Twitter' },
    { href: '#', label: 'RSS Feed' },
  ],
};
---

<footer class="bg-background-light dark:bg-background-dark border-t border-slate-200 dark:border-slate-800 pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-2">
        <div class="flex items-center gap-2 text-primary mb-6">
          <span class="material-symbols-outlined text-3xl">coffee</span>
          <h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold tracking-tight">Espresso Brews</h2>
        </div>
        <p class="text-slate-500 dark:text-slate-400 max-w-xs text-sm leading-relaxed">
          Your comprehensive resource for coffee brewing guides, espresso techniques, and specialty coffee knowledge.
        </p>
      </div>
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase tracking-widest mb-6">Guides</h4>
        <ul class="space-y-4">
          {footerLinks.research.map(link => (
            <li><a href={link.href} class="text-slate-500 dark:text-slate-400 text-sm hover:text-primary">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase tracking-widest mb-6">Resources</h4>
        <ul class="space-y-4">
          {footerLinks.company.map(link => (
            <li><a href={link.href} class="text-slate-500 dark:text-slate-400 text-sm hover:text-primary">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-xs">© 2026 Espresso Brews. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="text-slate-500 text-xs hover:text-primary">Privacy Policy</a>
        <a href="#" class="text-slate-500 text-xs hover:text-primary">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
